#!/bin/sh

uci -q batch <<-EOF >/dev/null
	delete ucitrack.@baidudrive[-1]
	add ucitrack baidudrive
	set ucitrack.@baidudrive[-1].init=baidudrive
	commit ucitrack
EOF

old_sdk_dir="$(uci -q get baidudrive.@baidudrive[0].sdk_dir)"
if [ "$old_sdk_dir" = "/opt/baidunas-sdk" ]; then
	uci -q set baidudrive.@baidudrive[0].sdk_dir="/usr/lib/baidusdk/nas_sdk"
	uci -q commit baidudrive
fi

/etc/init.d/baidudrive enable
/etc/init.d/baidudrive start

exit 0
